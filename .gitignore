# ==========================================
# 1. Token-Guard 专项：保留文件夹框架，忽略内部大文件
# ==========================================

# 允许文件夹存在，但忽略内部所有结果、权重和日志
eval/eval_results/*
!eval/eval_results/.gitkeep

models/*
!models/.gitkeep

log/*
!log/.gitkeep

# 忽略所有大型权重文件的后缀（双重保险）
*.safetensors
*.bin
*.pth
*.model
*.index.json

# 忽略数据集中的临时文件或备份
data/*.zip
data/*.tar.gz
copy/

# 忽略运行日志
nohup.out
*.log

# ==========================================
# 2. 必要的 Python 标准忽略规则 (精简版)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 虚拟环境
.env
.envrc
.venv
env/
venv/
ENV/

# 编辑器配置
.vscode/
.idea/
.ipynb_checkpoints/